    ],
    "schema_notes": {
      "damageTypes": "Fextralife uses 'Physical' as umbrella; split into specific subtypes (Standard/Slash/Strike/Pierce) per engine convention",
      "canInfuse_vs_uniqueWeapon": "Orthogonal. A unique weapon CAN be infused (e.g., Rusted Anchor). Crossbows/bows/ballistas have class-wide infusion restriction regardless of uniqueness.",
